{
  "expo": {
    "name": "BoraJogar",
    "slug": "borajogar",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "borajogar",
    "owner": "sgu_puc-rio",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/85228ab7-2f3e-4723-9fc8-8f76a8a89d2a",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "br.pucrio.borajogar",
      "supportsTablet": true
    },
    "android": {
      "package": "br.pucrio.borajogar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O BoraJogar precisa acessar sua galeria para definir a foto do jogador.",
          "cameraPermission": "O BoraJogar precisa acessar sua camera para tirar a foto do jogador.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/borajogar"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85228ab7-2f3e-4723-9fc8-8f76a8a89d2a"
      }
    }
  }
}
